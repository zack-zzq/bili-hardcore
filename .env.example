# Bili-Hardcore 环境配置
# 复制此文件为 .env 并填入你的配置

# ===== 必填: OpenAI Compatible API 配置 =====
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_API_KEY=your-api-key-here

# ===== 可选: 认证配置 (默认 admin/admin) =====
# AUTH_USERNAME=admin
# AUTH_PASSWORD=admin

# ===== 可选: JWT 密钥 (生产环境务必修改) =====
# JWT_SECRET=change-me-in-production

# ===== 可选: 服务端口 =====
# APP_PORT=8080
